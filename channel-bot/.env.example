# Required
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
CHANNEL_ID=@your_channel_name

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Comma-separated fallback RPCs (rotates on 429/5xx/timeout)
# SOLANA_RPC_URLS=https://api.mainnet-beta.solana.com,https://your-second-rpc.com,https://your-third-rpc.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Optional — enrichment APIs
GITHUB_TOKEN=ghp_your_github_pat
GROQ_API_KEY=gsk_your_groq_api_key
# Optional — X/Twitter follower counts & influencer detection (Twitter API v2 bearer token)
# TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Feed toggles (all default to true)
FEED_CLAIMS=true
FEED_LAUNCHES=true
FEED_GRADUATIONS=true
FEED_WHALES=true
FEED_FEE_DISTRIBUTIONS=true

# Tuning
POLL_INTERVAL_SECONDS=30
WHALE_THRESHOLD_SOL=10
LOG_LEVEL=info

# Health check server (Railway sets PORT automatically)
# PORT=3000
