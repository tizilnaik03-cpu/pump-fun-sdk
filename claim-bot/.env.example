# ── Required ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram and paste the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Solana RPC endpoint (mainnet-beta)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Optional ──────────────────────────────────────────────────────────────────
# WebSocket URL for real-time monitoring (derived from RPC if not set)
# Recommended: use a paid RPC (Helius, QuickNode, Triton) for reliable WS
# SOLANA_WS_URL=wss://atlas-mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Comma-separated fallback RPCs (rotates on 429/5xx/timeout)
# SOLANA_RPC_URLS=https://api.mainnet-beta.solana.com,https://your-second-rpc.com

# Polling interval in seconds (used when WebSocket is unavailable)
# POLL_INTERVAL_SECONDS=15

# Log level: debug | info | warn | error
# LOG_LEVEL=info
