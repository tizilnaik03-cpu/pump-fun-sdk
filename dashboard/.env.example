# Dashboard Environment Configuration
# Copy to .env and fill in your values

# ─── Server ─────────────────────────────────────────────────
DASHBOARD_PORT=8080
DASHBOARD_API_KEY=your-secret-api-key-here

# ─── Bot Service Endpoints ──────────────────────────────────
# Each bot's health endpoint URL. Set only the bots you run.
TELEGRAM_BOT_URL=http://localhost:3000
CHANNEL_BOT_URL=http://localhost:3002
OUTSIDERS_BOT_URL=http://localhost:3001
WEBSOCKET_SERVER_URL=http://localhost:3003

# ─── Telegram Bot API (for direct control) ──────────────────
TELEGRAM_BOT_API_KEY=
TELEGRAM_BOT_ENABLE_API=true

# ─── Solana RPC ─────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
